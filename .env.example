# --- Database ---
DATABASE_URL="file:./dev.db"

# --- Public base URL ---
# Must be the URL a phone's Lightning wallet can actually reach.
# For local dev with a real wallet, expose via a tunnel (cloudflared / ngrok)
# and put the https tunnel URL here. For simulated testing, http://localhost:3200 is fine.
NEXT_PUBLIC_BASE_URL="http://localhost:3200"

# --- Payout mode ---
# "true"  -> payouts are SIMULATED; no wallet needed (great for trying the flow).
# "false" -> real payouts; each voucher is funded by the issuer's own LNbits wallet,
#            entered in the "Connect your wallet" form when the voucher is created.
DEV_FAKE_PAYMENTS="true"

# --- Encryption ---
# Used to encrypt issuers' LNbits admin keys at rest (AES-256-GCM).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SPARKSTUB_SECRET=""

# --- Convenience ---
# Pre-fills the LNbits instance URL in the connect form (issuers can override).
NEXT_PUBLIC_DEFAULT_LNBITS_URL="https://demo.lnbits.com"
