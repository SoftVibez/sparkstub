{
  "name": "sparkstub",
  "version": "0.1.0",
  "private": true,
  "description": "Sparkstub — LNURL-withdraw vouchers. Print a QR, scan with any Lightning wallet, withdraw a preset amount of sats. One-time-use enforced.",
  "scripts": {
    "dev": "next dev -p 3200",
    "build": "prisma generate && prisma db push --skip-generate && next build",
    "start": "next start -p 3200",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "db:setup": "prisma db push && prisma generate",
    "test:flow": "tsx scripts/test-flow.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bech32": "^2.0.0",
    "next": "^14.2.35",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
